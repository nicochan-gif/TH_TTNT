def dong_tong_lon_nhat_45(a):
    max_sum = -10**9
    index = -1

    for i in range(len(a)):
        s = sum(a[i])
        if s > max_sum and s > 45:
            max_sum = s
            index = i

    return index
#e
def cot_tich_nho_nhat(a):
    m = len(a)
    n = len(a[0])

    min_tich = float('inf')
    index = -1

    for j in range(n):
        tich = 1
        for i in range(m):
            tich *= a[i][j]

        if tich < min_tich:
            min_tich = tich
            index = j

    return index
